# ============================================================
# Global defaults
# Template used by install.sh to generate machine-local Git config.
# ============================================================
[user]
	name = {{GIT_USER_NAME}}
	email = {{GIT_USER_EMAIL}}

[core]
	autocrlf = input
	safecrlf = false
	excludesfile = ~/.gitignore_global
# {{GIT_INCLUDE_BLOCKS}}
