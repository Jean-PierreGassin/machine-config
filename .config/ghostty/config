# Window
window-width = 180
window-height = 40

# Font
font-family = JetBrains Mono
font-size = 14
font-feature = -calt
font-feature = -clig
font-feature = -liga

# Theme
theme = Rose Pine Moon
selection-background = ffffff
selection-foreground = 000000

# Appearance
window-padding-x = 12
window-padding-y = 8
background-opacity = 0.9
background-blur = macos-glass-regular
macos-titlebar-style = tabs

# Cursor
cursor-style = block
cursor-style-blink = false

# Splits
unfocused-split-opacity = 0.7

# Behavior
confirm-close-surface = false

# Split create
keybind = ctrl+a>shift+backslash=new_split:right
keybind = ctrl+a>-=new_split:down

# Split navigate
keybind = ctrl+a>h=goto_split:left
keybind = ctrl+a>j=goto_split:down
keybind = ctrl+a>k=goto_split:up
keybind = ctrl+a>l=goto_split:right
keybind = ctrl+a>left=goto_split:left
keybind = ctrl+a>down=goto_split:down
keybind = ctrl+a>up=goto_split:up
keybind = ctrl+a>right=goto_split:right

# Split resize
keybind = ctrl+shift+h=resize_split:left,5
keybind = ctrl+shift+l=resize_split:right,5
keybind = ctrl+shift+j=resize_split:down,5
keybind = ctrl+shift+k=resize_split:up,5

# Zoom / close
keybind = ctrl+a>m=toggle_split_zoom
keybind = ctrl+a>x=close_surface

# Tabs
keybind = ctrl+a>c=new_tab
keybind = ctrl+a>p=previous_tab
keybind = ctrl+a>n=next_tab
keybind = ctrl+a>1=goto_tab:1
keybind = ctrl+a>2=goto_tab:2
keybind = ctrl+a>3=goto_tab:3
keybind = ctrl+a>4=goto_tab:4
keybind = ctrl+a>5=goto_tab:5
keybind = ctrl+a>6=goto_tab:6
keybind = ctrl+a>7=goto_tab:7
keybind = ctrl+a>8=goto_tab:8
keybind = ctrl+a>9=goto_tab:9
